{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "appearance": {
    "default": "dark",
    "isHidden": false,
    "strict": true
  },
  "background": {
    "color": {
      "light": "#ffffff",
      "dark": "#0a0a0a"
    }
  },
  "name": "Snipp",
  "description": "Snipp is the modern way to share your uploads with the world.",
  "colors": {
    "primary": "#171717",
    "light": "#404040",
    "dark": "#ffffff"
  },
  "favicon": "https://cdn.snipp.gg/favicon.ico",
  "seo": {
    "metatags": {
      "twitter:card": "summary_large_image",
      "og:image": "https://cdn.snipp.gg/banner.png",
      "twitter:image": "https://cdn.snipp.gg/banner.png"
    }
  },
  "api": {
    "baseUrl": "https://api.snipp.gg",
    "auth": {
      "method": "key",
      "name": "api-key",
      "inputPrefix": "api-key"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/file-types",
              "concepts/rate-limits",
              "concepts/plans"
            ]
          }
        ]
      },
      {
        "tab": "SDKs",
        "groups": [
          {
            "group": "SDKs",
            "pages": [
              "sdks/introduction",
              "sdks/node",
              "sdks/python",
              "sdks/rust",
              "sdks/shadowplay"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "api-reference/endpoint/users",
              "api-reference/endpoint/post",
              "api-reference/endpoint/upload",
              "api-reference/endpoint/uploads",
              "api-reference/endpoint/edit",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/discover"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "https://cdn.snipp.gg/logo_dark.png",
    "dark": "https://cdn.snipp.gg/logo_light.png"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Visit Snipp",
      "href": "https://snipp.gg"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "mcp", "cursor", "vscode"]
  },
  "footer": {
    "socials": {
      "discord": "https://snipp.gg/discord",
      "github": "https://snipp.gg/github",
      "x": "https://snipp.gg/x"
    }
  }
}