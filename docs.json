{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "appearance": {
    "default": "dark",
    "isHidden": false
  },
  "background": {
    "color": {
      "light": "#ffffff",
      "dark": "#0a0a0a"
    }
  },
  "name": "Snipp.gg",
  "description": "Image and video hosting API for Snipp.gg",
  "colors": {
    "primary": "#171717",
    "light": "#404040",
    "dark": "#ffffff"
  },
  "favicon": "https://cdn.snipp.gg/favicon.ico",
  "api": {
    "baseUrl": "https://api.snipp.gg",
    "auth": {
      "method": "key",
      "name": "api-key",
      "inputPrefix": "api-key"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "quickstart", "authentication"]
          },
          {
            "group": "Concepts",
            "pages": ["concepts/file-types", "concepts/rate-limits", "concepts/plans"]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Endpoints",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "api-reference/endpoint/users",
              "api-reference/endpoint/upload",
              "api-reference/endpoint/uploads",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/discover"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "https://cdn.snipp.gg/logo_dark.png",
    "dark": "https://cdn.snipp.gg/logo_light.png"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Visit Snipp",
      "href": "https://snipp.gg"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "mcp", "cursor", "vscode"]
  },
  "footer": {
    "socials": {
      "discord": "https://snipp.gg/discord",
      "github": "https://snipp.gg/github",
      "x": "https://snipp.gg/x"
    }
  }
}